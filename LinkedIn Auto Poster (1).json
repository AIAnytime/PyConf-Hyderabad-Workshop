        "jsCode": "// Get the raw output from the AI Agent node\nconst rawOutput = $json.output || \"\";\n\n// Remove ```json and ``` markers if present\nlet cleaned = rawOutput.replace(/```json|```/g, '').trim();\n\n// Parse JSON if it's valid\nlet post = \"\";\ntry {\n  const parsed = JSON.parse(cleaned);\n  post = parsed.post || \"\";\n} catch (e) {\n  post = cleaned; // fallback if JSON.parse fails\n}\n\n// Return a clean object\nreturn [{ json: { post } }];"
